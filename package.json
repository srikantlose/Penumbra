{
  "name": "penumbra",
  "version": "0.1.0",
  "private": true,
  "description": "Chess platform mapping the solved frontier",
  "author": "Srikaanth",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "db:smoke": "node scripts/db-smoke.mjs",
    "fetch:syzygy": "node scripts/fetch-syzygy.mjs",
    "fetch:engines": "node scripts/fetch-engines.mjs",
    "ledger:publish": "node scripts/publish-proofs.mjs",
    "ledger:verify": "node scripts/verify-ledger.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.33.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.24.0",
    "turbo": "^2.0.0"
  }
}
