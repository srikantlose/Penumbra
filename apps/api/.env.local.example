# apps/api reads env vars straight from process.env (no dotenv loader) --
# export these into your shell before `pnpm dev`, or use direnv / your own
# tooling to load them. DATABASE_URL / PORT / WEB_ORIGIN / MINIO_* all have
# working local-dev defaults in src/context.ts and don't need to be set here.

# Required for "connect Lichess account" (POST /bff/lichess/oauth/*):
# AES-256-GCM key encrypting users.oauth_tokens at rest. 32 bytes, hex-encoded
# (64 hex characters) -- there is no dev fallback for this one, unlike the
# infra defaults above, since it protects a real bearer credential. Generate
# with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Optional: the OAuth client_id sent to Lichess. Not a secret (it's visible
# in the redirect URL), so it defaults to "penumbra-local-dev" if unset.
LICHESS_OAUTH_CLIENT_ID=
