# Copy to .env.local (gitignored) and fill in real values.

# Base URL of the running apps/api service.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-only: used by the /journey page's import Server Action to call
# POST /bff/import. Never exposed to the browser (not NEXT_PUBLIC_-prefixed).
# Mint one with: node scripts/seed-dev-api-key.mjs
PENUMBRA_API_KEY=
